// Content Review Dashboard — Database Schema
// Target: AWS Aurora Serverless v2 (PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// WRITERS
// ============================================================
model Writer {
  id              String   @id @default(cuid())
  name            String
  email           String?  @unique
  driveFolderId   String   @unique @map("drive_folder_id")
  driveFolderName String?  @map("drive_folder_name")
  avatarUrl       String?  @map("avatar_url")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  articles Article[]

  // Aggregate stats (denormalized for fast dashboard queries)
  totalArticles    Int   @default(0) @map("total_articles")
  avgPlagiarism    Float @default(0) @map("avg_plagiarism")
  avgAiScore       Float @default(0) @map("avg_ai_score")
  avgGrammarScore  Float @default(0) @map("avg_grammar_score")

  @@map("writers")
}

// ============================================================
// ARTICLES
// ============================================================
model Article {
  id            String        @id @default(cuid())
  writerId      String        @map("writer_id")
  writer        Writer        @relation(fields: [writerId], references: [id])

  // Google Drive metadata
  googleDocId   String        @unique @map("google_doc_id")
  title         String
  driveUrl      String        @map("drive_url")
  wordCount     Int?          @map("word_count")
  
  // Processing status
  status        ArticleStatus @default(DETECTED)
  detectedAt    DateTime      @default(now()) @map("detected_at")
  submittedAt   DateTime?     @map("submitted_at")
  completedAt   DateTime?     @map("completed_at")
  
  // Copyleaks tracking
  copyleaksScanId String?     @unique @map("copyleaks_scan_id")
  aiDetectionLevel  Int       @default(2) @map("ai_detection_level")
  
  // Content snapshot (for AI text extraction & Copyleaks submission)
  content       String?       @db.Text              // Full text submitted to Copyleaks
  contentHash   String?       @map("content_hash") // MD5 to detect re-edits
  lastModified  DateTime?     @map("last_modified")

  scanResult    ScanResult?
  
  @@index([writerId, status])
  @@index([status])
  @@index([detectedAt])
  @@map("articles")
}

enum ArticleStatus {
  DETECTED    // Found in Drive, not yet submitted
  QUEUED      // In submission queue
  SCANNING    // Sent to Copyleaks, awaiting results
  COMPLETED   // Results received
  REVIEWED    // Editor has reviewed
  APPROVED    // Passed review
  FLAGGED     // Needs writer revision
  ERROR       // Scan failed
  ARCHIVED    // Removed from Drive folder or manually archived
}

// ============================================================
// SCAN RESULTS
// ============================================================
model ScanResult {
  id            String   @id @default(cuid())
  articleId     String   @unique @map("article_id")
  article       Article  @relation(fields: [articleId], references: [id])

  // Copyleaks identifiers
  copyleaksScanId String  @map("copyleaks_scan_id")

  // ---- Plagiarism ----
  plagiarismScore     Float   @default(0) @map("plagiarism_score")     // 0-100%
  matchedWords        Int     @default(0) @map("matched_words")
  totalWords          Int     @default(0) @map("total_words")
  
  // ---- AI Detection ----
  aiScore             Float   @default(0) @map("ai_score")             // 0-1.0 probability
  humanScore          Float   @default(0) @map("human_score")          // 0-1.0 probability
  
  // ---- Writing Quality (Grammar Checker) ----
  grammarScore        Float?  @map("grammar_score")         // 0-100
  mechanicsScore      Float?  @map("mechanics_score")       // 0-100
  sentenceStructure   Float?  @map("sentence_structure")    // 0-100
  wordChoice          Float?  @map("word_choice")           // 0-100
  readabilityGrade    String? @map("readability_grade")     // e.g., "8th Grade"
  readingTimeMinutes  Float?  @map("reading_time_minutes")

  // ---- Source Matches (plagiarism detail) ----
  sources     ScanSource[]
  
  // ---- Paragraph-level AI Detection ----
  paragraphs  AiParagraph[]

  // Raw JSON response for drill-down
  rawResponse Json?    @map("raw_response")
  
  // PDF report
  pdfReportUrl String? @map("pdf_report_url")

  scannedAt   DateTime @default(now()) @map("scanned_at")

  @@map("scan_results")
}

// ============================================================
// PLAGIARISM SOURCE MATCHES
// ============================================================
model ScanSource {
  id            String     @id @default(cuid())
  scanResultId  String     @map("scan_result_id")
  scanResult    ScanResult @relation(fields: [scanResultId], references: [id], onDelete: Cascade)

  sourceUrl     String     @map("source_url")
  sourceTitle   String?    @map("source_title")
  matchedWords  Int        @map("matched_words")
  percentage    Float      // % of article that matches this source
  isInternetSource Boolean @default(true) @map("is_internet_source")

  @@index([scanResultId])
  @@map("scan_sources")
}

// ============================================================
// PER-PARAGRAPH AI CLASSIFICATION
// ============================================================
model AiParagraph {
  id            String     @id @default(cuid())
  scanResultId  String     @map("scan_result_id")
  scanResult    ScanResult @relation(fields: [scanResultId], references: [id], onDelete: Cascade)

  paragraphIndex Int       @map("paragraph_index")
  text           String
  classification String   // "ai" | "human" | "mixed"
  aiProbability  Float    @map("ai_probability") // 0-1.0

  @@index([scanResultId])
  @@map("ai_paragraphs")
}

// ============================================================
// PRACTICE BRAND GUIDES
// ============================================================
model Practice {
  id              String   @id @default(cuid())
  name            String   @unique                    // "Ada Smile Place"
  titlePrefix     String   @unique @map("title_prefix") // "Ada Smile Place" - matched against article title
  website         String?
  brandVoiceNotes String?  @db.Text @map("brand_voice_notes") // Free-text brand voice guidelines
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Source documents for auto-extraction
  sourceFolderId  String?  @map("source_folder_id")  // Google Drive folder with project docs

  // Website monitoring
  lastWebsiteCheck  DateTime?  @map("last_website_check")
  websiteSnapshot   Json?      @map("website_snapshot")  // Last scraped data for comparison

  doctors       PracticeDoctor[]
  services      PracticeService[]
  bannedPhrases BannedPhrase[]
  styleRules    StyleRule[]
  editorialIssues EditorialIssue[]
  websiteChanges  WebsiteChange[]

  @@map("practices")
}

// ============================================================
// WEBSITE CHANGE TRACKING
// ============================================================
model WebsiteChange {
  id          String   @id @default(cuid())
  practiceId  String   @map("practice_id")
  practice    Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  changeType  String   @map("change_type")     // "doctor_added", "doctor_removed", "service_added", "service_removed", "hours_changed", "team_changed"
  field       String                            // Which field changed
  oldValue    String?  @db.Text @map("old_value")
  newValue    String?  @db.Text @map("new_value")
  severity    String   @default("info")         // "error" | "warning" | "info"

  status      String   @default("pending")      // "pending" | "acknowledged" | "dismissed"
  resolvedAt  DateTime? @map("resolved_at")

  detectedAt  DateTime @default(now()) @map("detected_at")

  @@index([practiceId, status])
  @@map("website_changes")
}

model PracticeDoctor {
  id              String   @id @default(cuid())
  practiceId      String   @map("practice_id")
  practice        Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  fullName        String   @map("full_name")          // "Dr. Jane Smith, DDS"
  preferredFormat String   @map("preferred_format")    // How name should appear in content
  role            String?                               // "Lead Dentist", "Orthodontist", etc.
  isActive        Boolean  @default(true) @map("is_active")

  @@index([practiceId])
  @@map("practice_doctors")
}

model PracticeService {
  id          String   @id @default(cuid())
  practiceId  String   @map("practice_id")
  practice    Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  serviceName String   @map("service_name")            // "Invisalign", "Dental Implants"
  isOffered   Boolean  @default(true) @map("is_offered") // true = they offer it, false = explicitly DON'T

  @@index([practiceId])
  @@map("practice_services")
}

model BannedPhrase {
  id              String   @id @default(cuid())
  practiceId      String   @map("practice_id")
  practice        Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  phrase          String                                // "cheap", "discount", "pain"
  suggestedAlt    String?  @map("suggested_alt")       // "affordable", "special offer", "discomfort"
  reason          String?                               // Why it's banned
  severity        String   @default("warning")          // "error" | "warning"

  @@index([practiceId])
  @@map("banned_phrases")
}

model StyleRule {
  id          String   @id @default(cuid())
  practiceId  String   @map("practice_id")
  practice    Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  rule        String                                    // "Always capitalize 'Invisalign'"
  category    String   @default("general")              // "capitalization", "terminology", "tone", "general"

  @@index([practiceId])
  @@map("style_rules")
}

// ============================================================
// EDITORIAL ISSUES (Gemini-detected brand violations)
// ============================================================
model EditorialIssue {
  id          String   @id @default(cuid())
  articleId   String   @map("article_id")
  practiceId  String   @map("practice_id")
  practice    Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  type        String                                    // "name_violation", "banned_phrase", "service_mismatch", "style_violation", "brand_voice"
  severity    String   @default("warning")              // "error" | "warning" | "info"
  
  // Location in article
  originalText  String  @db.Text @map("original_text")  // The problematic text
  charStart     Int?    @map("char_start")
  charEnd       Int?    @map("char_end")
  
  // Suggestion
  suggestedFix  String? @db.Text @map("suggested_fix")  // What it should say
  explanation   String? @db.Text                         // Why this is an issue
  
  // Editor action
  editorAction  String?  @map("editor_action")          // "accepted" | "rejected" | "edited"
  editorNote    String?  @db.Text @map("editor_note")
  resolvedAt    DateTime? @map("resolved_at")
  
  // Google Doc sync
  pushedToDoc   Boolean  @default(false) @map("pushed_to_doc")
  
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([articleId])
  @@index([practiceId])
  @@map("editorial_issues")
}

// ============================================================
// SYSTEM CONFIG / SYNC STATE
// ============================================================
model SyncState {
  id            String   @id @default(cuid())
  folderId      String   @unique @map("folder_id")
  lastSyncToken String?  @map("last_sync_token")  // Google Drive change token
  lastSyncAt    DateTime @default(now()) @map("last_sync_at")
  
  @@map("sync_state")
}

// ============================================================
// APP SETTINGS (key-value store for OAuth tokens, config, etc.)
// ============================================================
model AppSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("app_settings")
}

// ============================================================
// AUTH (NextAuth.js)
// ============================================================
model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model AllowedUser {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      String   @default("editor")
  addedAt   DateTime @default(now()) @map("added_at")

  @@map("allowed_users")
}
